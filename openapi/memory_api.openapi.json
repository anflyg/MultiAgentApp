{
  "openapi": "3.1.0",
  "info": {
    "title": "MultiAgentApp Memory API",
    "version": "0.1.0",
    "description": "Thin local API for memory orientation and memory read/search."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8001"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "db_path"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "db_path": {
            "type": "string",
            "example": "SocratesTest.db"
          }
        }
      },
      "MemoryOrientRequest": {
        "type": "object",
        "required": [
          "question"
        ],
        "properties": {
          "question": {
            "type": "string"
          },
          "workspace_id": {
            "type": "string"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "default": 3
          }
        }
      },
      "TopMatch": {
        "type": "object",
        "required": [
          "id",
          "title",
          "summary",
          "relevance_score",
          "match_basis"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "relevance_score": {
            "type": "number",
            "format": "float"
          },
          "match_basis": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "MemoryOrientResponse": {
        "type": "object",
        "required": [
          "question",
          "workspace",
          "top_matches",
          "memory_belongs",
          "novelty_assessment",
          "reasoning"
        ],
        "properties": {
          "question": {
            "type": "string"
          },
          "workspace": {
            "type": "string"
          },
          "top_matches": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TopMatch"
            }
          },
          "memory_belongs": {
            "type": "string",
            "enum": [
              "likely_related",
              "weakly_related",
              "no_clear_match"
            ]
          },
          "novelty_assessment": {
            "type": "string",
            "enum": [
              "existing",
              "partly_new",
              "new"
            ]
          },
          "reasoning": {
            "type": "string"
          }
        }
      },
      "MemorySearchRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "workspace_id": {
            "type": "string"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "default": 10
          }
        }
      },
      "MemorySearchItem": {
        "type": "object",
        "required": [
          "id",
          "title",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "relevance_score": {
            "type": "number",
            "format": "float"
          },
          "match_basis": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "MemorySearchResponse": {
        "type": "object",
        "required": [
          "workspace",
          "count",
          "items"
        ],
        "properties": {
          "workspace": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MemorySearchItem"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/memory/orient": {
      "post": {
        "summary": "Orient question against long-term memory",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MemoryOrientRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Orientation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemoryOrientResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/memory/search": {
      "post": {
        "summary": "Search memory objects in workspace scope",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MemorySearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemorySearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/memory/{id}": {
      "get": {
        "summary": "Get one memory object by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workspace_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Memory object found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}
