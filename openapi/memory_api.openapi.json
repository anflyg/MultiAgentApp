{
  "openapi": "3.1.0",
  "info": {
    "title": "MultiAgentApp Memory API",
    "version": "0.2.0",
    "description": "Thin local API for memory orientation and memory read/search. Intended for first Custom GPT Action pilot."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8001",
      "description": "Local development server"
    },
    {
      "url": "https://your-tunnel-host.example",
      "description": "Public HTTPS tunnel URL for ChatGPT Actions"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "system",
      "description": "System status endpoints"
    },
    {
      "name": "memory",
      "description": "Memory orientation and read/search endpoints"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token from --api-token or MULTI_AGENT_APP_API_TOKEN."
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "db_path"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "db_path": {
            "type": "string",
            "example": "./SocratesTest.db"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "MemoryOrientRequest": {
        "type": "object",
        "required": [
          "question"
        ],
        "properties": {
          "question": {
            "type": "string"
          },
          "workspace_id": {
            "type": "string"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "default": 3
          }
        }
      },
      "OrientationTopMatch": {
        "type": "object",
        "required": [
          "id",
          "title",
          "summary",
          "relevance_score",
          "match_basis"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "relevance_score": {
            "type": "number",
            "format": "float"
          },
          "match_basis": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "MemoryOrientResponse": {
        "type": "object",
        "required": [
          "question",
          "workspace",
          "top_matches",
          "memory_belongs",
          "novelty_assessment",
          "reasoning"
        ],
        "properties": {
          "question": {
            "type": "string"
          },
          "workspace": {
            "type": "string"
          },
          "top_matches": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrientationTopMatch"
            }
          },
          "memory_belongs": {
            "type": "string",
            "enum": [
              "likely_related",
              "weakly_related",
              "no_clear_match"
            ]
          },
          "novelty_assessment": {
            "type": "string",
            "enum": [
              "existing",
              "partly_new",
              "new"
            ]
          },
          "reasoning": {
            "type": "string"
          }
        }
      },
      "MemoryObject": {
        "type": "object",
        "required": [
          "id",
          "workspace_id",
          "title",
          "summary",
          "memory_type",
          "status",
          "assumptions",
          "risks",
          "triggers",
          "relations",
          "sources",
          "revision_notes",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "workspace_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "memory_type": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "draft",
              "archived"
            ]
          },
          "decision_text": {
            "type": [
              "string",
              "null"
            ]
          },
          "assumptions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "triggers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "relations": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "revision_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MemorySearchRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Optional text query. If omitted, endpoint lists workspace memories."
          },
          "workspace_id": {
            "type": "string",
            "description": "Optional workspace id. Defaults to active workspace."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "default": 10
          }
        }
      },
      "MemorySearchItem": {
        "type": "object",
        "required": [
          "id",
          "title",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "relevance_score": {
            "type": "number",
            "format": "float"
          },
          "match_basis": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "MemorySearchResponse": {
        "type": "object",
        "required": [
          "workspace",
          "count",
          "items"
        ],
        "properties": {
          "workspace": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MemorySearchItem"
            }
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "system"
        ],
        "operationId": "getHealth",
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "API is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/memory/orient": {
      "post": {
        "tags": [
          "memory"
        ],
        "operationId": "postMemoryOrient",
        "summary": "Orient question against long-term memory",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MemoryOrientRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Orientation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemoryOrientResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/memory/search": {
      "post": {
        "tags": [
          "memory"
        ],
        "operationId": "postMemorySearch",
        "summary": "Search memory objects in workspace scope",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MemorySearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemorySearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/memory/{id}": {
      "get": {
        "tags": [
          "memory"
        ],
        "operationId": "getMemoryById",
        "summary": "Get one memory object by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workspace_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Memory object found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemoryObject"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}
